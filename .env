# ─────────────────────────────────────────────────────────────────
#  EmailJS credentials — replace the placeholder values below with
#  your real keys from https://www.emailjs.com/
#
#  STEP 1: Sign up / log in at emailjs.com
#  STEP 2: "Email Services" → Add Service → Gmail → copy Service ID
#  STEP 3: "Email Templates" → Create Template → copy Template ID
#  STEP 4: "Account" → API Keys → copy Public Key
#  STEP 5: Paste the three values below and save this file
#  STEP 6: Restart `npm run dev` — Vite picks up env changes on restart
#
#  ⚠️  Never commit this file to Git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────

VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
