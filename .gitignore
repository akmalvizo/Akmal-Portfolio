# ────────────────────────────────────────────────────────────────
#  ml-portfolio — .gitignore
#  All entries below are EXCLUDED from GitHub.
#  Everything else gets committed.
# ────────────────────────────────────────────────────────────────

# ── Dependencies (reinstall with: npm install) ──────────────────
node_modules/
package.json

# ── Production build output (generated by: npm run build) ───────
dist/

# ── Vite dev-server cache (auto-regenerated) ────────────────────
node_modules/.vite/
node_modules/.vite-temp/

# ── Environment variables (may contain secrets / API keys) ───────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── OS-generated junk ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor & IDE config (personal, not needed by others) ─────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Kiro AI spec files (internal workspace tool) ─────────────────
.kiro/

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime / temp files ─────────────────────────────────────────
*.local
*.tmp
*.temp

# ── Optional: lock file (uncomment if you prefer not to commit it)
# package-lock.json


node_modules
dist